/* 全局样式 */
page {
  background-color: #F7F8FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  color: #1A1D26;
  --primary: #FF6B6B;
  --success: #2ECC71;
  --text-main: #2C3E50;
  --text-sub: #95A5A6;
  --card-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.nebula-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 400px;
  background: linear-gradient(180deg, #FFF0F0 0%, #F7F8FA 100%);
  z-index: -1;
  pointer-events: none;
}

.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(50px);
  opacity: 0.5;
}
.blob-1 {
  top: -60px; right: -40px;
  width: 220px; height: 220px;
  background: #FF6B6B;
  animation: breathe 8s infinite ease-in-out;
}
.blob-2 {
  top: 100px; left: -40px;
  width: 160px; height: 160px;
  background: #4ECDC4;
  opacity: 0.3;
  animation: float 10s infinite ease-in-out;
}

@keyframes breathe { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(20px); } }

/* 头部区域 */
.header-section {
  padding: 0 24px 20px;
  position: relative;
  z-index: 10;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  left: 16px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(8px);
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.5);
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.back-arrow {
  font-size: 24px;
  color: #2C3E50;
  line-height: 1;
  margin-top: -2px;
  margin-left: -2px;
}

.nav-placeholder {
  height: 0;
}

.title-group {
  margin-bottom: 24px;
  padding-top: 100px; /* 适配自定义导航栏 */
}

.page-title {
  font-size: 28px;
  font-weight: 800;
  color: #2C3E50;
  margin-bottom: 4px;
}

.page-subtitle {
  font-size: 13px;
  color: #7F8C8D;
  font-weight: 500;
}

/* 资产卡片 */
.asset-card {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 24px;
  padding: 24px 28px;
  color: #fff;
  position: relative;
  overflow: hidden;
  box-shadow: 0 10px 25px rgba(255, 107, 107, 0.3);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-bg-decoration {
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200px;
  height: 200px;
  background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.asset-info {
  position: relative;
  z-index: 2;
}

.label {
  font-size: 13px;
  opacity: 0.9;
  margin-bottom: 8px;
}

.value-row {
  display: flex;
  align-items: baseline;
}

.value {
  font-size: 40px;
  font-weight: 700;
  font-family: 'DIN Alternate', sans-serif;
  line-height: 1;
}

.unit {
  font-size: 14px;
  margin-left: 6px;
  opacity: 0.9;
}

.asset-icon {
  font-size: 48px;
  opacity: 0.9;
  transform: rotate(10deg);
}

/* 列表容器 */
.list-container {
  flex: 1;
  background: #FFFFFF;
  border-top-left-radius: 32px;
  border-top-right-radius: 32px;
  box-shadow: 0 -10px 30px rgba(0,0,0,0.03);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  padding: 20px 24px 10px;
  gap: 12px;
  border-bottom: 1px solid #F7F8FA;
}

.filter-item {
  padding: 6px 16px;
  border-radius: 20px;
  font-size: 13px;
  color: #95A5A6;
  background: #F7F8FA;
  transition: all 0.2s;
}

.filter-item.active {
  background: #2C3E50;
  color: #FFFFFF;
  font-weight: 600;
}

/* 滚动列表 */
.scroll-view {
  flex: 1;
  height: 0;
}

.log-list {
  padding: 16px 24px 40px;
}

/* 记录卡片 */
.log-card {
  display: flex;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid #F7F8FA;
}

.log-card:last-child {
  border-bottom: none;
}

.icon-box {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16px;
  font-size: 20px;
}

.icon-box.income {
  background: #FFF0F0;
  color: #FF6B6B;
}

.icon-box.expense {
  background: #F0F2F5;
  color: #95A5A6;
}

.info-box {
  flex: 1;
  overflow: hidden;
}

.log-title {
  font-size: 15px;
  color: #2C3E50;
  font-weight: 600;
  margin-bottom: 4px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.log-meta {
  display: flex;
  align-items: center;
  gap: 8px;
}

.log-type-tag {
  font-size: 10px;
  padding: 2px 6px;
  background: #F7F8FA;
  color: #95A5A6;
  border-radius: 4px;
}

.log-time {
  font-size: 11px;
  color: #BDC3C7;
}

.value-box {
  text-align: right;
}

.points-num {
  font-size: 18px;
  font-weight: 700;
  font-family: 'DIN Alternate', sans-serif;
}

.points-num.plus {
  color: #FF6B6B;
}

.points-num.minus {
  color: #2C3E50;
}

/* 状态提示 */
.state-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
  color: #BDC3C7;
  font-size: 13px;
}

.empty-emoji {
  font-size: 48px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.loader {
  width: 24px;
  height: 24px;
  border: 2px solid #FF6B6B;
  border-radius: 50%;
  border-top-color: transparent;
  animation: spin 0.8s linear infinite;
  margin-bottom: 12px;
}

.footer-state {
  text-align: center;
  padding: 20px 0;
  color: #BDC3C7;
  font-size: 12px;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* 动画 */
.animate-slide-down { animation: slideDown 0.6s ease-out forwards; }
.animate-slide-up { animation: slideUp 0.6s ease-out forwards; opacity: 0; }
.card-hover { transform: scale(0.99); }

@keyframes slideDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
