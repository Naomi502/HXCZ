/* 全局样式 */
page {
  background-color: #F7F8FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  color: #1A1D26;
  --primary: #FF6B6B;
  --card-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.nebula-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 400px;
  background: linear-gradient(180deg, #FFF0F0 0%, #F7F8FA 100%);
  z-index: 0;
  pointer-events: none;
}

.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(50px);
  opacity: 0.5;
}
.blob-1 {
  top: -60px; right: -40px;
  width: 220px; height: 220px;
  background: #FF6B6B;
  animation: breathe 8s infinite ease-in-out;
}
.blob-2 {
  top: 100px; left: -40px;
  width: 160px; height: 160px;
  background: #4ECDC4;
  opacity: 0.3;
  animation: float 10s infinite ease-in-out;
}

@keyframes breathe { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(20px); } }
@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

.animate-slide-up {
  opacity: 0;
  animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* 头部导航栏 */
.header-bar {
  position: relative;
  z-index: 10;
  padding: 0 24px;
  padding-top: 100px; /* 适配自定义导航栏 */
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 10px;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  left: 16px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(8px);
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.5);
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.back-arrow {
  font-size: 24px;
  color: #2C3E50;
  line-height: 1;
  margin-top: -2px;
  margin-left: -2px;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.page-title {
  font-size: 28px;
  font-weight: 800;
  color: #2C3E50;
  letter-spacing: -0.5px;
  margin-bottom: 4px;
}

.page-subtitle {
  font-size: 13px;
  color: #7F8C8D;
  font-weight: 500;
}

/* 滚动容器 */
.scroll-container {
  flex: 1;
  position: relative;
  z-index: 5;
  height: 0;
}

.content-wrapper {
  padding: 10px 24px;
}

.info-bar {
  display: flex;
  justify-content: center;
  margin-bottom: 24px;
}

/* 时间提示 Badge */
.time-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  background: rgba(255, 255, 255, 0.6);
  border: 1px solid rgba(255, 255, 255, 0.6);
  border-radius: 20px;
  font-size: 12px;
  color: #7F8C8D;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
}

.time-badge .icon {
  font-size: 14px;
}

/* 图表卡片 */
.chart-card {
  background: #ffffff;
  border-radius: 24px;
  padding: 24px;
  margin-bottom: 24px;
  box-shadow: var(--card-shadow);
  border: 1px solid rgba(255, 255, 255, 0.8);
  transition: transform 0.2s ease;
}

.chart-card:active {
  transform: scale(0.99);
}

.card-header {
  margin-bottom: 20px;
}

.card-title-group {
  display: flex;
  align-items: center;
  gap: 16px;
}

/* 图标容器 */
.icon-box {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  flex-shrink: 0;
}

.icon-box.type-star {
  background: #FFF7E6;
  color: #FAAD14;
}

.icon-box.type-heart {
  background: #FFF0F6;
  color: #EB2F96;
}

.icon-box.type-target {
  background: #E6F7FF;
  color: #1890FF;
}

.text-info {
  display: flex;
  flex-direction: column;
}

.chart-label {
  font-size: 16px;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 2px;
}

.chart-desc {
  font-size: 12px;
  color: #95A5A6;
}

/* Canvas 容器 */
.canvas-container {
  width: 100%;
  height: 200px;
  position: relative;
}

.chart-canvas {
  width: 100%;
  height: 100%;
}

/* 加载状态 */
.loading-overlay {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
}

.spinner-container {
  width: 40px;
  height: 40px;
}

.loading-spinner {
  width: 100%;
  height: 100%;
  border: 3px solid rgba(255, 107, 107, 0.1);
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 14px;
  color: #95A5A6;
}
