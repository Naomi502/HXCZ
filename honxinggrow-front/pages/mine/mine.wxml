<view class="page {{runAnim ? 'animate-entry' : 'anim-reset'}}">
  <!-- 背景装饰 -->
  <view class="nebula-bg">
    <view class="blob blob-1"></view>
    <view class="blob blob-2"></view>
  </view>

  <view class="container">
    
    <!-- 用户信息区域 -->
    <view class="user-profile animate-slide-down">
      
      <!-- 头像区域 -->
      <view class="avatar-area">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{localAvatar || profile.avatarUrl}}" class="avatar-img" src="{{localAvatar || profile.avatarUrl}}" mode="aspectFill"></image>
          <view wx:else class="avatar-text-placeholder">
            <text wx:if="{{isLoggedIn}}">{{userName[0] || '红'}}</text>
            <text wx:else>未</text>
          </view>
        </button>
        <view class="camera-badge" wx:if="{{isLoggedIn}}">
          <text>📷</text>
        </view>
      </view>

      <!-- 信息区域 -->
      <view class="info-area" bindtap="handleProfileCardTap">
        <view class="name-row">
          <text class="username">{{isLoggedIn ? userName : '点击登录账号'}}</text>
          <view class="role-tag" wx:if="{{isLoggedIn}}">
            <text class="icon">🎓</text> 红芯成员
          </view>
        </view>
        <view class="desc-row">
          {{isLoggedIn ? '信息工程学院' : '登录后体验更多功能'}}
        </view>
      </view>
      
      <view class="arrow-box">
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 数据概览卡片 -->
    <view class="stats-card animate-slide-up" style="animation-delay: 0.1s;">
      <view class="stat-item" bindtap="goToPointsDetail" hover-class="hover-opacity">
        <view class="stat-value">{{isLoggedIn ? totalPoints : '-'}}</view>
        <view class="stat-label">我的积分</view>
      </view>
      <view class="divider"></view>
      <view class="stat-item" bindtap="goToLikedStories" hover-class="hover-opacity">
        <view class="stat-value">{{isLoggedIn ? (storyCount || 0) : '-'}}</view>
        <view class="stat-label">已赞故事</view>
      </view>
      <view class="divider"></view>
      <view class="stat-item" bindtap="goToMyActivities" hover-class="hover-opacity">
        <view class="stat-value">{{isLoggedIn ? (activityCount || 0) : '-'}}</view>
        <view class="stat-label">参与活动</view>
      </view>
    </view>

    <!-- 核心功能菜单 (左一右二布局) -->
    <view class="menu-grid animate-slide-up" style="animation-delay: 0.2s;" wx:if="{{isLoggedIn}}">
      
      <!-- 左侧：心灵树洞 -->
      <view class="grid-col-left">
        <view class="bento-card treehole-card pink" bindtap="goToTreeHole" hover-class="card-hover">
           <view class="card-icon-big">🌳</view>
           <view class="card-info-bottom">
             <view class="card-title-lg">心灵树洞</view>
             <view class="card-desc">温暖倾诉，解忧杂货铺</view>
           </view>
           <view class="card-bg-icon">🌳</view>
        </view>
      </view>
      
      <!-- 右侧：活动与成长 -->
      <view class="grid-col-right">
        <view class="bento-card small-card blue" bindtap="goToMyActivities" hover-class="card-hover">
          <view class="card-content-row">
             <view class="card-info-side">
               <view class="card-title">我的活动</view>
               <view class="card-desc">活动记录</view>
             </view>
             <view class="card-icon-small">🏅</view>
          </view>
        </view>
        
        <view class="bento-card small-card orange" bindtap="goToGrowthHistory" hover-class="card-hover">
          <view class="card-content-row">
             <view class="card-info-side">
               <view class="card-title">成长历程</view>
               <view class="card-desc">数据分析</view>
             </view>
             <view class="card-icon-small">📈</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 常用功能列表 -->
    <view class="list-menu animate-slide-up" style="animation-delay: 0.3s;" wx:if="{{isLoggedIn}}">
      <view class="menu-item" bindtap="goToMessageCenter" hover-class="list-hover">
        <view class="menu-left">
          <view class="menu-icon-box green"><text>🔔</text></view>
          <text class="menu-name">消息中心</text>
          <view class="badge" wx:if="{{unreadCount > 0}}">{{unreadCount}}</view>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="goToPointsDetail" hover-class="list-hover">
        <view class="menu-left">
          <view class="menu-icon-box purple"><text>📊</text></view>
          <text class="menu-name">积分明细</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="goToAccountSettings" hover-class="list-hover">
        <view class="menu-left">
          <view class="menu-icon-box gray"><text>⚙️</text></view>
          <text class="menu-name">账号设置</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="handleLogout" hover-class="list-hover">
        <view class="menu-left">
          <view class="menu-icon-box red-light"><text>🚪</text></view>
          <text class="menu-name" style="color: #FF6B6B;">退出登录</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    
    <!-- 未登录提示 -->
    <view class="login-guide animate-slide-up" style="animation-delay: 0.2s;" wx:if="{{!isLoggedIn}}">
      <image class="guide-img" src="/images/login-bg.svg" mode="aspectFit"></image> <!-- 假设有个图，没有就用文字 -->
      <view class="guide-text">登录后开启红芯之旅</view>
      <button class="guide-btn" bindtap="showLoginModal">立即登录</button>
    </view>

  </view>

  <!-- 登录弹窗 (保持原有逻辑，仅优化样式) -->
  <view wx:if="{{showLoginModal}}" class="modal-mask animate-fade-in">
    <view class="modal-box animate-pop">
      <view wx:if="{{loginMode === 'wechat'}}" class="login-wechat">
        <view class="modal-header">
          <text class="modal-title">欢迎回来</text>
          <view class="modal-close" bindtap="closeLoginModal">✕</view>
        </view>
        <view class="wechat-icon-box">
          <image class="wechat-icon" src="/images/wechat.png"></image>
        </view>
        <button class="btn-wechat" loading="{{wechatLoginLoading}}" bindtap="handleWechatQuickLogin">
          微信一键登录
        </button>
        <view class="wechat-tip">{{wechatBound ? '已绑定微信，可直接登录' : '首次登录将自动绑定微信'}}</view>
        <view class="switch-login" bindtap="switchToAccountLogin">使用账号密码登录</view>
      </view>

      <view wx:if="{{loginMode === 'account'}}" class="login-account">
        <view class="modal-header">
          <view class="back-btn" bindtap="switchToWechatLogin">←</view>
          <text class="modal-title">账号登录</text>
          <view class="modal-close" bindtap="closeLoginModal">✕</view>
        </view>
        <view class="input-group">
          <input class="input" placeholder="请输入账号" bindinput="onLoginUsernameInput" />
          <input class="input" password placeholder="请输入密码" bindinput="onLoginPasswordInput" />
        </view>
        <button class="btn-primary" loading="{{loginSubmitting}}" bindtap="handleInlineLogin">登录</button>
        <view class="forget-pwd">忘记密码？请联系辅导员</view>
      </view>
    </view>
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-mask">
    <view class="loader"></view>
  </view>
</view>
