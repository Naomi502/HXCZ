/* 全局容器 */
.page {
  min-height: 100vh;
  background-color: #faf8f5; /* 更柔和的灰蓝背景 */
  display: flex;
  justify-content: center;
  padding-top: 40px;
  box-sizing: border-box;
}

.container {
  width: 100%;
  padding: 0 20px;
}

/* 头部文字区域 */
.header {
  margin-bottom: 24px;
  padding-left: 4px;
}

.title {
  font-size: 28px;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8px;
  letter-spacing: 0.5px;
}

.subtitle {
  font-size: 14px;
  color: #9ca3af;
}

/* 卡片主体 */
.card {
  background: #ffffff;
  border-radius: 24px; /* 更大的圆角 */
  padding: 30px 24px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04); /* 弥散阴影 */
}

/* 提示条 */
.notice-bar {
  background: #fff6f7; /* 极浅的粉色背景，呼应主题色 */
  border-radius: 12px;
  padding: 12px 16px;
  display: flex;
  align-items: flex-start;
  margin-bottom: 24px;
}

.notice-icon {
  color: #ff6b81;
  margin-right: 8px;
  font-size: 14px;
  font-weight: bold;
}

.notice-bar text:last-child {
  font-size: 13px;
  color: #666;
  line-height: 1.4;
  flex: 1;
}

/* 表单区域 */
.form {
  display: flex;
  flex-direction: column;
  gap: 20px; /* 增加间距 */
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.input-label {
  font-size: 14px;
  font-weight: 600;
  color: #374151;
  margin-left: 4px;
}

.input {
  height: 48px; /* 加高点击区域 */
  line-height: 48px;
  padding: 0 16px;
  border-radius: 14px;
  background-color: #f3f4f6; /* 默认浅灰背景，无边框 */
  border: 1px solid transparent;
  font-size: 15px;
  color: #111;
  transition: all 0.3s ease; /* 添加过渡动画 */
}

.input-placeholder {
  color: #9ca3af;
  font-size: 14px;
}

/* 输入框聚焦态 */
.input:focus {
  background-color: #fff;
  border-color: #ff6b81;
  box-shadow: 0 0 0 3px rgba(255, 107, 129, 0.15); /* 聚焦时光晕 */
}

/* 提交按钮 */
.submit-btn {
  margin-top: 16px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff6b81, #ff9966);
  color: #ffffff;
  border-radius: 25px;
  font-size: 16px;
  font-weight: 600;
  letter-spacing: 1px;
  border: none;
  /* 按钮投影，让它浮起来 */
  box-shadow: 0 8px 20px rgba(255, 107, 129, 0.3);
  transition: transform 0.1s;
}

.submit-btn::after {
  border: none; /* 去除小程序默认边框 */
}

/* 按钮点击态 */
.submit-btn-hover {
  transform: scale(0.98); /* 点击微缩效果 */
  opacity: 0.9;
  box-shadow: 0 4px 12px rgba(255, 107, 129, 0.3);
}

.bind-card {
  margin-top: 24px;
  padding: 24px;
  margin-bottom: 20px;
}

.bind-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 20px;
}

.bind-title {
  font-size: 18px;
  font-weight: 600;
  color: #111827;
  margin-bottom: 4px;
}

.bind-desc {
  font-size: 13px;
  color: #6b7280;
  line-height: 1.5;
}

.bind-status {
  padding: 6px 20px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 600;
  background: #f3f4f6;
  color: #6b7280;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.bind-status.on {
  background: rgba(16, 185, 129, 0.15);
  color: #059669;
}

.bind-status.off {
  background: rgba(248, 113, 113, 0.15);
  color: #dc2626;
}

.bind-btn {
  height: 46px;
  border-radius: 23px;
  border: none;
  background: linear-gradient(135deg, #10b981, #059669);
  color: #fff;
  font-size: 15px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bind-btn[disabled] {
  background: #e5e7eb;
  color: #9ca3af;
}

.bind-btn-hover {
  opacity: 0.9;
}