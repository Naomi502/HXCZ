/* 全局样式 */
page {
  background-color: #F7F8FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  color: #1A1D26;
  --primary: #FF6B6B;
  --primary-light: #FFEDED;
  --secondary: #4ECDC4;
  --card-bg: #FFFFFF;
  --text-main: #2C3E50;
  --text-sub: #95A5A6;
  --card-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* 顶部背景装饰 */
.nebula-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 400px;
  background: linear-gradient(180deg, #FFF0F0 0%, #F7F8FA 100%);
  z-index: 0;
  pointer-events: none;
}

.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(50px);
  opacity: 0.5;
}
.blob-1 {
  top: -60px; right: -40px;
  width: 200px; height: 200px;
  background: #FF6B6B;
  animation: breathe 8s infinite ease-in-out;
}
.blob-2 {
  top: 60px; left: -40px;
  width: 150px; height: 150px;
  background: #4ECDC4;
  opacity: 0.3;
  animation: float 10s infinite ease-in-out;
}

@keyframes breathe { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(20px); } }
@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

.animate-slide-up {
  opacity: 0;
  animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* 头部导航栏 */
.header-bar {
  position: relative;
  z-index: 10;
  padding: 0 24px;
  padding-top: 100px; /* 适配自定义导航栏 */
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 10px;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  left: 16px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(8px);
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.5);
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.back-arrow {
  font-size: 24px;
  color: #2C3E50;
  line-height: 1;
  margin-top: -2px;
  margin-left: -2px;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.page-title {
  font-size: 28px;
  font-weight: 800;
  color: #2C3E50;
  letter-spacing: -0.5px;
  margin-bottom: 4px;
}

.page-subtitle {
  font-size: 13px;
  color: #7F8C8D;
  font-weight: 500;
}

/* 滚动容器 */
.scroll-container {
  flex: 1;
  position: relative;
  z-index: 5;
  height: 0;
}

.content-wrapper {
  padding: 10px 20px;
}

/* 设置卡片 */
.settings-card {
  background: var(--card-bg);
  border-radius: 24px;
  padding: 24px;
  margin-bottom: 20px;
  box-shadow: var(--card-shadow);
  position: relative;
  overflow: hidden;
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  margin-bottom: 20px;
}

.icon-box {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  flex-shrink: 0;
}

.icon-box.blue { background: #E6F7FF; color: #1890FF; }
.icon-box.green { background: #E8F5E9; color: #4CAF50; }

.header-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-top: 2px;
}

.card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4px;
}

.card-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-main);
}

.card-desc {
  font-size: 13px;
  color: var(--text-sub);
  line-height: 1.4;
}

/* 状态标签 */
.status-badge {
  padding: 4px 12px;
  border-radius: 100px;
  font-size: 12px;
  font-weight: 600;
}

.status-badge.success {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-badge.warning {
  background: #FFF7E6;
  color: #FA8C16;
}

/* 按钮样式 */
.action-btn {
  height: 48px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  border: none;
  transition: all 0.3s;
}

.action-btn.primary {
  background: linear-gradient(135deg, #10b981, #059669);
  color: #fff;
  box-shadow: 0 8px 20px rgba(16, 185, 129, 0.2);
}

.action-btn.disabled {
  background: #F5F5F5;
  color: #BDBDBD;
  box-shadow: none;
}

.submit-btn {
  margin-top: 24px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff6b81, #ff9966);
  color: #ffffff;
  border-radius: 25px;
  font-size: 16px;
  font-weight: 600;
  letter-spacing: 1px;
  border: none;
  box-shadow: 0 8px 20px rgba(255, 107, 129, 0.3);
  transition: transform 0.1s;
}

.btn-hover {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 表单样式 */
.form-group {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.input-item {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.input-label {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-main);
  margin-left: 4px;
}

.input-field {
  height: 48px;
  background: #F7F8FA;
  border-radius: 14px;
  padding: 0 16px;
  font-size: 15px;
  color: var(--text-main);
  transition: all 0.3s;
}

.input-field:focus {
  background: #FFFFFF;
  box-shadow: 0 0 0 2px rgba(255, 107, 107, 0.1);
}

.input-placeholder {
  color: #BDC3C7;
}

/* 提示条 */
.notice-bar {
  background: #FFF0F0;
  border-radius: 12px;
  padding: 12px 16px;
  display: flex;
  align-items: flex-start;
  margin-bottom: 20px;
}

.notice-icon {
  color: #FF6B6B;
  margin-right: 8px;
  font-size: 14px;
  font-weight: bold;
}

.notice-bar text:last-child {
  font-size: 13px;
  color: #7F8C8D;
  line-height: 1.4;
  flex: 1;
}
