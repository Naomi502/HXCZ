<view class="page">
  <view class="container">
    <view class="header">
      <view class="title">修改密码</view>
      <view class="subtitle">为了保障您的账户安全，请定期更换密码</view>
    </view>
    <view class="card bind-card">
      <view class="bind-header">
        <view>
          <view class="bind-title">微信快捷登录</view>
          <view class="bind-desc">修改密码后点击下方按钮绑定，可使用微信快捷登录。</view>
        </view>
        <view class="bind-status {{wechatBound ? 'on' : 'off'}}">
          {{wechatBound ? '已绑定' : '未绑定'}}
        </view>
      </view>
      <button class="bind-btn" hover-class="bind-btn-hover" loading="{{bindingWechat}}" disabled="{{wechatBound}}" bindtap="handleBindWechat">
        {{wechatBound ? '已完成绑定' : '绑定微信'}}
      </button>
    </view>
    <view class="card">
      <!-- 提示条 -->
      <view class="notice-bar">
        <text class="notice-icon">ⓘ</text>
        <text>首次登录请先修改默认密码，如需调整其他信息请联系学院老师。</text>
      </view>

      <view class="form">
        <view class="input-group">
          <view class="input-label">旧密码</view>
          <input class="input" password placeholder="请输入当前密码" placeholder-class="input-placeholder" value="{{oldPassword}}" bindinput="onOldPwdInput" />
        </view>
        
        <view class="input-group">
          <view class="input-label">新密码</view>
          <input class="input" password placeholder="请输入新密码（至少6位）" placeholder-class="input-placeholder" value="{{newPassword}}" bindinput="onNewPwdInput" />
        </view>

        <view class="input-group">
          <view class="input-label">确认密码</view>
          <input class="input" password placeholder="请再次输入新密码" placeholder-class="input-placeholder" value="{{confirmPassword}}" bindinput="onConfirmPwdInput" />
        </view>

        <button class="submit-btn" hover-class="submit-btn-hover" loading="{{submitting}}" bindtap="handleSubmit">确认修改</button>
      </view>
    </view>


  </view>
</view>