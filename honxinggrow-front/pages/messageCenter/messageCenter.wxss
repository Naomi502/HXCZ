/* 全局样式 */
page {
  background-color: #F7F8FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  color: #1A1D26;
  --primary: #FF6B6B;
  --primary-light: #FFEDED;
  --secondary: #4ECDC4;
  --card-bg: #FFFFFF;
  --text-main: #2C3E50;
  --text-sub: #95A5A6;
  --card-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* 顶部背景装饰 */
.nebula-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 400px;
  background: linear-gradient(180deg, #FFF0F0 0%, #F7F8FA 100%);
  z-index: 0;
  pointer-events: none;
}

.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(50px);
  opacity: 0.5;
}
.blob-1 {
  top: -60px; right: -40px;
  width: 200px; height: 200px;
  background: #FF6B6B;
  animation: breathe 8s infinite ease-in-out;
}
.blob-2 {
  top: 60px; left: -40px;
  width: 150px; height: 150px;
  background: #4ECDC4;
  opacity: 0.3;
  animation: float 10s infinite ease-in-out;
}

@keyframes breathe { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(20px); } }

/* 头部导航栏 */
.header-bar {
  position: relative;
  z-index: 10;
  padding: 0 24px;
  padding-top: 100px; /* 适配自定义导航栏 */
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 10px;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  left: 16px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(8px);
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.5);
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.back-arrow {
  font-size: 24px;
  color: #2C3E50;
  line-height: 1;
  margin-top: -2px;
  margin-left: -2px;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.page-title {
  font-size: 28px;
  font-weight: 800;
  color: #2C3E50;
  letter-spacing: -0.5px;
  margin-bottom: 4px;
}

.page-subtitle {
  font-size: 13px;
  color: #7F8C8D;
  font-weight: 500;
}

/* 一键清除按钮 */
.clear-all-btn {
  font-size: 12px;
  color: #95A5A6;
  background: rgba(255, 255, 255, 0.5);
  padding: 6px 12px;
  border-radius: 100px;
  border: 1px solid rgba(0, 0, 0, 0.05);
  backdrop-filter: blur(4px);
  margin-top: 4px;
}

.clear-all-btn:active {
  background: #f0f0f0;
  opacity: 0.8;
}

/* 滚动容器 */
.scroll-container {
  flex: 1;
  position: relative;
  z-index: 5;
  height: 0;
}

.card-list {
  padding: 10px 20px;
}

/* 消息卡片 */
.message-card {
  background: var(--card-bg);
  border-radius: 20px;
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: var(--card-shadow);
  position: relative;
  transition: all 0.3s;
  overflow: hidden;
}

.message-card.unread-glow {
  box-shadow: 0 8px 20px rgba(255, 107, 107, 0.1);
  border-left: 4px solid #FF6B6B;
  padding-left: 16px;
}

.message-card:active {
  transform: scale(0.99);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  gap: 16px;
}

.icon-box {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  flex-shrink: 0;
}

.icon-box.blue { background: #E6F7FF; color: #1890FF; }
.icon-box.green { background: #E8F5E9; color: #4CAF50; }
.icon-box.orange { background: #FFF7E6; color: #FA8C16; }

.header-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

.msg-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}

.msg-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 90%;
}

.msg-title.text-unread {
  color: #2C3E50;
  font-weight: 700;
}

.status-dot {
  width: 8px;
  height: 8px;
  background: #FF6B6B;
  border-radius: 50%;
  margin-left: 8px;
}

.msg-time {
  font-size: 12px;
  color: #95A5A6;
}

.arrow-icon {
  font-size: 20px;
  color: #D3D3D3;
  transition: transform 0.3s;
}

.arrow-icon.expanded {
  transform: rotate(90deg);
  color: #2C3E50;
}

/* 卡片内容区 (展开收起) */
.card-body {
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card-body.expanded {
  max-height: 500px;
  opacity: 1;
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid #F7F8FA;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
}

.msg-content {
  font-size: 14px;
  color: #57606F;
  line-height: 1.6;
  text-align: justify;
}

.actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16px;
}

.delete-btn {
  font-size: 12px;
  color: #BDC3C7;
  padding: 6px 12px;
  border-radius: 12px;
  background: #F7F8FA;
  display: flex;
  align-items: center;
  gap: 4px;
  transition: all 0.2s;
}

.delete-btn:active {
  background: #FFEBEE;
  color: #FF6B6B;
}

.delete-icon {
  font-size: 12px;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120px;
}

.empty-icon {
  font-size: 80px;
  margin-bottom: 16px;
  opacity: 0.6;
  animation: float 6s infinite ease-in-out;
}

.empty-text {
  font-size: 16px;
  color: #2C3E50;
  font-weight: 600;
  margin-bottom: 8px;
}

.empty-subtext {
  font-size: 13px;
  color: #95A5A6;
}

/* 动画 */
.animate-slide-up {
  animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  opacity: 0;
  transform: translateY(20px);
}

@keyframes slideUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
