/* 全局样式 */
page {
  background-color: #faf8f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  color: #1A1D26;
  --primary: #FF4B4B;
  --card-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
}

.page {
  min-height: 100vh;
  position: relative;
}

/* 背景装饰层 (Fixed定位，解决错位) */
.nebula-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 400px;
  background: linear-gradient(180deg, #FFF0F0 0%, #faf8f5 100%);
  z-index: -1;
  overflow: hidden;
}

.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(40px);
  opacity: 0.6;
}
.blob-1 {
  top: -50px;
  right: -60px;
  width: 220px;
  height: 220px;
  background: #FF4B4B;
  animation: breathe 8s infinite ease-in-out;
}
.blob-2 {
  top: 100px;
  left: -40px;
  width: 160px;
  height: 160px;
  background: #7F2FFF;
  opacity: 0.3;
  animation: float 10s infinite ease-in-out;
}

@keyframes breathe { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(20px); } }

/* 页面容器 */
.container {
  padding: 20px;
  padding-top: 30px;
  padding-bottom: 50px;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  left: 16px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(8px);
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.5);
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.back-arrow {
  font-size: 24px;
  color: #2C3E50;
  line-height: 1;
  margin-top: -2px;
  margin-left: -2px;
}

/* 标题区域 */
.header {
  text-align: center;
  margin-bottom: 40px;
  padding-top: 70px; /* 增加顶部间距，适配自定义导航栏 */
  position: relative;
  z-index: 2;
}

.title {
  display: block;
  font-size: 28px;
  font-weight: 800;
  color: #2C3E50;
  margin-bottom: 8px;
}

.subtitle {
  display: block;
  font-size: 12px;
  color: #858B9C;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 0;
  position: relative;
  z-index: 2;
  animation: fadeIn 0.4s ease-out forwards;
}

.spinner {
  width: 40px;
  height: 40px;
  border: 4px solid #f3f3f3;
  border-top: 4px solid #722ED1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16px;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 14px;
  color: #858B9C;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 0;
  text-align: center;
  position: relative;
  z-index: 2;
  animation: slideUp 0.6s ease-out forwards;
  opacity: 0;
}

.empty-icon {
  font-size: 80px;
  margin-bottom: 24px;
}

.empty-title {
  font-size: 18px;
  font-weight: 600;
  color: #1A1D26;
  margin-bottom: 12px;
}

.empty-subtitle {
  font-size: 14px;
  color: #858B9C;
  margin-bottom: 32px;
  padding: 0 40px;
}

.empty-btn {
  background: linear-gradient(135deg, #722ED1 0%, #9254DE 100%);
  color: #ffffff;
  border: none;
  border-radius: 24px;
  padding: 12px 32px;
  font-size: 15px;
  font-weight: 600;
  box-shadow: 0 8px 24px rgba(114, 46, 209, 0.3);
  transition: transform 0.2s;
}

.empty-btn:active {
  transform: scale(0.98);
}

.empty-btn::after {
  border: none;
}

/* 消息列表 */
.message-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
  position: relative;
  z-index: 2;
}

/* 消息项 */
.message-item {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 16px 20px;
  box-shadow: var(--card-shadow);
  position: relative;
  animation: slideUp 0.6s ease-out forwards;
  opacity: 0;
  animation-delay: calc(var(--index) * 0.1s);
}

/* 消息内容 */
.message-content {
  font-size: 15px;
  color: #1A1D26;
  line-height: 1.6;
  margin-bottom: 12px;
  word-break: break-word;
  white-space: pre-wrap;
}

/* 消息时间 */
.message-time {
  font-size: 12px;
  color: #C1C4CC;
  text-align: right;
}

/* 动画类 */
@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }