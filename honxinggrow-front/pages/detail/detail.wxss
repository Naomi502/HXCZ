/* detail.wxss - 故事详情页样式 */
page {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  min-height: 100vh;
  /* 更高级的纸张白/暖色调 */
  background-color: #fcfcfc;
  background-image: radial-gradient(circle at 10% 20%, rgba(255, 241, 230, 0.4) 0%, transparent 20%),
                    radial-gradient(circle at 90% 80%, rgba(255, 235, 235, 0.4) 0%, transparent 20%);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: #1d1d1f;
}

.page {
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
}

/* 背景装饰 */
.nebula-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 400px;
  background: linear-gradient(180deg, #fff5f5 0%, #fcfcfc 100%);
  z-index: -1;
  pointer-events: none;
}

.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
  opacity: 0.6;
}
.blob-1 {
  top: -80px; right: -60px;
  width: 240px; height: 240px;
  background: #ffccc7;
  animation: breathe 10s infinite ease-in-out;
}
.blob-2 {
  top: 120px; left: -60px;
  width: 180px; height: 180px;
  background: #e6f7ff;
  opacity: 0.4;
  animation: float 12s infinite ease-in-out;
}

@keyframes breathe { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(20px); } }

/* 返回按钮 */
.back-btn {
  position: fixed;
  left: 16px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(8px);
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.5);
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.back-arrow {
  font-size: 24px;
  color: #2C3E50;
  line-height: 1;
  margin-top: -2px;
  margin-left: -2px;
}

/* Loading 状态 */
.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
  backdrop-filter: blur(5px);
}

.spinner-container {
  width: 40px;
  height: 40px;
  margin-bottom: 16px;
}

.loading-spinner {
  width: 100%;
  height: 100%;
  border: 3px solid #ffeef0;
  border-top-color: #ff4d4f;
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.68, -0.55, 0.27, 1.55) infinite;
}

.loading-text {
  font-size: 13px;
  color: #99aab5;
  letter-spacing: 1px;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* === 主体内容区 === */
.detail-container {
  padding-bottom: 40px;
}

/* 1. 头部信息区 */
.header-area {
  padding: 105px 24px 30px; /* 顶部留出导航栏空间 */
  position: relative;
}

.main-title {
  font-size: 28px;
  font-weight: 800;
  color: #1d1d1f;
  line-height: 1.3;
  margin-bottom: 16px;
  display: block;
  letter-spacing: -0.5px;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.meta-tag {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: #86909c;
  background: rgba(255, 255, 255, 0.5);
  padding: 4px 10px;
  border-radius: 12px;
  border: 1px solid rgba(0,0,0,0.02);
}

.meta-divider {
  width: 1px;
  height: 12px;
  background: #e5e6eb;
}

.meta-tag .icon {
  font-size: 14px;
}

/* 2. 摘要卡片 (玻璃态) */
.summary-glass {
  margin: 0 24px 30px;
  padding: 24px;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10px);
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.02);
  position: relative;
}

.quote-icon {
  font-family: serif;
  font-size: 40px;
  color: #ffd8bf;
  position: absolute;
  line-height: 1;
}

.quote-icon.left {
  top: 10px;
  left: 10px;
}

.quote-icon.right {
  bottom: -10px;
  right: 16px;
  transform: rotate(180deg);
}

.summary-text {
  font-size: 15px;
  color: #595959;
  line-height: 1.8;
  font-style: italic;
  text-align: justify;
  display: block;
  position: relative;
  z-index: 1;
}

/* 3. 正文内容卡片 */
.content-card {
  margin: 0 24px 40px;
}

.richtext-wrapper {
  margin-bottom: 10px;
}

.article-text {
  font-size: 17px;
  line-height: 1.85;
  color: #262626;
  text-align: justify;
  letter-spacing: 0.2px;
}

.article-image {
  width: 100%;
  border-radius: 16px;
  margin: 24px 0;
  box-shadow: 0 12px 36px rgba(0, 0, 0, 0.08);
  display: block;
}

/* 底部互动区 */
.interaction-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30px;
  margin-top: 10px;
}

.divider-line {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  color: #d9d9d9;
  font-size: 12px;
  font-family: serif;
  letter-spacing: 2px;
  opacity: 0.6;
}

.divider-line::before,
.divider-line::after {
  content: '';
  width: 40px;
  height: 1px;
  background: #e8e8e8;
}

/* 点赞按钮 (FAB风格) */
.like-fab {
  width: auto !important;
  min-width: 140px;
  height: 56px;
  padding: 0 32px;
  border-radius: 28px;
  background: #ffffff;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  border: 1px solid rgba(0, 0, 0, 0.02);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  flex-shrink: 0;
}

.like-fab.active {
  background: linear-gradient(135deg, #ff7875, #ff4d4f);
  box-shadow: 0 12px 32px rgba(255, 77, 79, 0.25);
  border: none;
}

.fab-icon {
  font-size: 22px;
  flex-shrink: 0;
}

.fab-text {
  font-size: 16px;
  font-weight: 600;
  color: #595959;
  white-space: nowrap;
  flex-shrink: 0;
}

.like-fab.active .fab-text,
.like-fab.active .fab-count {
  color: #ffffff;
}

.fab-count {
  font-size: 14px;
  color: #8c8c8c;
  background: rgba(0, 0, 0, 0.04);
  padding: 2px 8px;
  border-radius: 10px;
  margin-left: 4px;
  flex-shrink: 0;
  white-space: nowrap;
}

.like-fab.active .fab-count {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.fab-hover {
  transform: scale(0.96);
}

/* 4. 相关推荐 */
.recommend-section {
  padding-top: 20px;
  border-top: 1px solid #f0f0f0;
  margin: 0 24px;
}

.section-title {
  margin-bottom: 20px;
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.title-text {
  font-size: 20px;
  font-weight: 700;
  color: #1d1d1f;
}

.title-sub {
  font-size: 12px;
  font-family: 'DIN Alternate', sans-serif;
  color: #bfbfbf;
  letter-spacing: 1px;
}

/* 横向滚动列表 */
.recommend-scroll {
  white-space: nowrap;
  width: 100%;
  height: 220px; /* 增加高度以容纳阴影 */
  margin-left: -4px; /* 修正padding造成的左移 */
  padding-left: 4px;
}

.recommend-card {
  display: inline-block;
  width: 160px;
  margin-right: 16px;
  background: #ffffff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.04);
  vertical-align: top;
  transition: transform 0.3s ease;
}

.recommend-card:active {
  transform: scale(0.98);
}

.rec-cover {
  width: 100%;
  height: 100px;
  background: #f5f5f5;
}

.rec-info {
  padding: 12px;
  white-space: normal; /* 允许换行 */
}

.rec-title {
  font-size: 14px;
  font-weight: 600;
  color: #262626;
  line-height: 1.4;
  height: 40px; /* 限制两行高度 */
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 8px;
}

.rec-meta {
  font-size: 11px;
  color: #999;
}
