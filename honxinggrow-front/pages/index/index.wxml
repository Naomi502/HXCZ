<view class="page {{runAnim ? 'animate-entry' : 'anim-reset'}}">
<!-- 顶部背景装饰：流体星云 (高动态版) -->
<view class="deco-layer">
  <!-- 1. 巨型主星：缓慢自转，作为氛围底色 -->
  <view class="blob blob-giant"></view>
  <!-- 2. 游动卫星：大幅度位移，穿梭在主星周围 -->
  <view class="blob blob-wander"></view>
  <!-- 3. 灵动光点：快速浮动，制造高光亮点 -->
  <view class="blob blob-spark"></view>
</view>

  <!-- 消息提示栏 (顶部悬浮) -->
  <view class="msg-tip-bar {{isMsgTipHiding ? 'animate-slide-up-hide' : 'animate-slide-down'}}" wx:if="{{showMsgTip}}" bindtap="onMsgTipTap">
    <view class="msg-content">
      <view class="bell-icon">🔔</view>
      <text>您有 {{unreadCount}} 条新消息通知</text>
    </view>
    <view class="arrow-right">›</view>
  </view>

  <!-- 头部 Hero 区域 -->
  <view class="hero">
    <image class="hero-bg" src="/images/banner.jpg" mode="aspectFill"></image>
    <view class="hero-overlay"></view> <!-- 渐变遮罩 -->
    
    <view class="hero-content animate-slide-down">
      <view class="hero-header">
        <view class="hero-pill">
          <view class="dot"></view>红芯成长精选
        </view>
        <view class="online-badge">
          <view class="pulse-dot"></view> 2人在线
        </view>
      </view>
      
      <view class="hero-text-group">
        <view class="hero-title">让每一个故事<text class="highlight">被看到</text></view>
        <view class="hero-subtitle">用温度记录成长 · 用故事连接彼此</view>
      </view>
    </view>

    <!-- 数据统计条：改为悬浮玻璃态 -->
    <view class="hero-stats-glass animate-slide-down" style="animation-delay: 0.1s;">
      <view class="stat-item">
        <text class="stat-num">{{storyList.length || 0}}</text>
        <text class="stat-label">精选故事</text>
      </view>
      <view class="stat-line"></view>
      <view class="stat-item">
        <text class="stat-num">Daily</text>
        <text class="stat-label">每日更新</text>
      </view>
    </view>
  </view>

  <!-- 主体内容区（上移覆盖Hero底部） -->
  <view class="main-container">
    
    <!-- 搜索栏 -->
    <view class="search-section animate-fade-in" style="animation-delay: 0.2s;">
      <view class="search-box {{!isLoggedIn ? 'disabled' : ''}}">
        <icon class="search-icon" type="search" size="20" color="#FF5E5E" />
        <input
          class="search-input"
          type="text"
          placeholder="{{isLoggedIn ? '搜索故事标题、摘要或关键词' : '登录后探索更多故事'}}"
          placeholder-class="placeholder-style"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          disabled="{{!isLoggedIn}}"
        />
        <view class="search-action" wx:if="{{searchKeyword}}" bindtap="onClearSearch">
          <icon type="clear" size="18" color="#CCCDDE" />
        </view>
      </view>
      <!-- 装饰性阴影 -->
      <view class="search-shadow"></view>
    </view>

    <!-- 未登录提示卡片 -->
    <view class="login-wrapper animate-fade-in" style="animation-delay: 0.3s;" wx:if="{{!isLoggedIn}}">
      <view class="login-glass-card" hover-class="card-hover" >
        <view class="icon-box">
          <image class="lock-img" src="/images/lock-icon.png" mode="aspectFit" wx:if="{{false}}"></image> <!-- 这里可以换图片，暂用文字代替 -->
          <text style="font-size:24px;">🔒</text>
        </view>
        <view class="login-info">
          <text class="login-h1">解锁完整体验</text>
          <text class="login-p">登录即可浏览全部故事，同步积分轨迹</text>
        </view>
        <view class="login-btn" bindtap="goToAccount">去登录</view>
      </view>
    </view>

    <!-- 故事列表区域 -->
    <view wx:if="{{isLoggedIn}}">
      <view class="section-header animate-fade-in" style="animation-delay: 0.3s;">
        <view class="header-left">
          <text class="title">最新故事</text>
          <text class="badge">New</text>
        </view>
      </view>

      <view class="story-list">
        <!-- 空状态 -->
        <view class="empty-state animate-fade-in" wx:if="{{filteredStories.length === 0 && !loading}}">
          <view class="empty-img-box">
            <image src="/images/activity_default.jpg" mode="aspectFill"></image>
          </view>
          <text class="empty-t1">暂无相关故事</text>
          <text class="empty-t2">去看看别的角落吧</text>
        </view>

        <!-- 列表循环：加入 index 用于动画延时 -->
        <view 
          class="story-card-wrap animate-slide-up" 
          wx:for="{{filteredStories}}" 
          wx:key="id" 
          style="animation-delay: {{index * 0.1 + 0.4}}s"
          bindtap="viewDetail" 
          data-id="{{item.id}}"
          hover-class="card-press"
          hover-stay-time="100"
        >
          <view class="story-card">
            <view class="card-visual">
              <image src="{{item.coverUrl}}" mode="aspectFill" lazy-load></image>
              <view class="visual-overlay"></view>
              <view class="category-tag">精选</view>
            </view>
            
            <view class="card-content">
              <view class="card-main">
                <view class="story-title">{{item.title}}</view>
                <view class="story-desc">{{item.summary}}</view>
              </view>
              
              <view class="card-footer">
                <view class="author-info">
                   <text class="publish-date">{{item.publishTime}}</text>
                </view>
                <view class="interaction-data">
                  <view class="data-item">
                    <text class="icon">👁</text> {{item.views}}
                  </view>
                  <view class="data-item liked">
                    <text class="icon">❤</text> {{item.likes}}
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 加载更多 -->
        <view class="loading-bar" wx:if="{{loading}}">
           <view class="spinner"></view>
           <text>精彩故事加载中...</text>
        </view>
        
        <view class="loading-bar" wx:if="{{!loading && filteredStories.length > 0}}">
           <text>— 已经到底啦 —</text>
        </view>
      </view>
    </view>
  </view>
</view>