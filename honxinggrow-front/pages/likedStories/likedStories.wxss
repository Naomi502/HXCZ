/* 复用通用样式 */
page {
  --primary: #FF4B4B;
  --text-main: #1A1D26;
  --text-sub: #858B9C;
  --bg-page: #faf8f5;
  --card-bg: #FFFFFF;
  --shadow-card: 0 8px 24px rgba(0, 0, 0, 0.04);
  background-color: var(--bg-page);
}

.page {
  min-height: 100vh;
  padding-bottom: 30px;
}

/* 顶部导航 */
.custom-nav {
  display: flex;
  align-items: center;
  padding-left: 16px;
  position: relative;
  z-index: 100;
}

.back-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(4px);
  border-radius: 50%;
  margin-right: 12px;
}

.back-arrow {
  font-size: 24px;
  color: #333;
  margin-top: -2px;
}

.nav-title {
  font-size: 17px;
  font-weight: 600;
  color: #333;
}

/* 主容器 */
.main-container {
  padding: 20px 20px 0;
}

/* 故事卡片样式 (与首页保持一致) */
.story-card-wrap {
  margin-bottom: 20px;
}

.card-press .story-card {
  transform: scale(0.97);
}

.story-card {
  background: var(--card-bg);
  border-radius: 20px;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.card-visual {
  position: relative;
  height: 160px; /* 稍微调小一点 */
  background: #F0F2F5;
}

.card-visual image { width: 100%; height: 100%; display: block; }

.visual-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0) 50%, rgba(0,0,0,0.3) 100%);
}

.category-tag {
  position: absolute;
  top: 12px;
  left: 12px;
  background: rgba(255, 75, 75, 0.9);
  color: #fff;
  font-size: 10px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 100px;
}

.card-content {
  padding: 16px 18px;
}

.story-title {
  font-size: 17px;
  font-weight: 700;
  color: var(--text-main);
  line-height: 1.4;
  margin-bottom: 6px;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.story-desc {
  font-size: 13px;
  color: #5D6376;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12px;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid #F5F6F8;
  padding-top: 12px;
}

.publish-date { font-size: 11px; color: #9CA3AF; }

.interaction-data { display: flex; gap: 12px; }
.data-item { font-size: 11px; color: #9CA3AF; display: flex; align-items: center; gap: 4px; }
.data-item.liked { color: #FF5E5E; }

/* Empty State */
.empty-state {
  text-align: center;
  padding: 60px 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.empty-img-box {
  width: 160px;
  height: 120px;
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 20px;
  opacity: 0.8;
}
.empty-img-box image { width: 100%; height: 100%; }
.empty-t1 { font-size: 16px; font-weight: 600; color: var(--text-main); margin-bottom: 6px; }
.empty-t2 { font-size: 13px; color: var(--text-sub); }

/* Loading */
.loading-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  padding: 20px 0;
  color: var(--text-sub);
  font-size: 12px;
}
.spinner {
  width: 14px;
  height: 14px;
  border: 2px solid #E5E6EB;
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
