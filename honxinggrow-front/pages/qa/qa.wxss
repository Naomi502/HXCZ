/* QA 页面样式 - 参考 index 页面设计 */
page {
  --primary: #FF4B4B;
  --primary-light: #FFF0F0;
  --text-main: #1A1D26;
  --text-sub: #858B9C;
  --bg-page: #faf8f5;
  --card-bg: #FFFFFF;
  --shadow-soft: 0 10px 40px rgba(200, 200, 200, 0.15);
  --shadow-card: 0 8px 24px rgba(0, 0, 0, 0.04);
  
  --nav-height: 0px;
  --human-height: 340rpx;
  --input-height: 80rpx;
  --input-padding-v: 16rpx;
  --input-padding-h: 32rpx;
  --tabbar-height: 100rpx;
  --input-total-height: calc(var(--input-height) + var(--input-padding-v) * 2 + var(--tabbar-height));
  
  background-color: var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', sans-serif;
  height: 100vh;
  overflow: hidden;
}

/* 主容器 */
.qa-page {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  background-color: var(--bg-page);
  overflow: hidden;
}

/* ========== 导航栏 ========== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: transparent;
}

.status-bar {
  width: 100%;
  background: transparent;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--input-padding-h);
  position: relative;
}

.nav-left {
  position: absolute;
  left: var(--input-padding-h);
  top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 0.5px;
}

.online-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  background: rgba(16, 185, 129, 0.1);
  border-radius: 24rpx;
  border: 1px solid rgba(16, 185, 129, 0.2);
  transition: all 0.3s ease;
}

.online-badge.thinking {
  background: rgba(245, 158, 11, 0.1);
  border-color: rgba(245, 158, 11, 0.2);
}

.pulse-dot {
  width: 12rpx;
  height: 12rpx;
  background: #10B981;
  border-radius: 50%;
  box-shadow: 0 0 12rpx rgba(16, 185, 129, 0.6);
  animation: pulse-dot 2s ease-in-out infinite;
}

.online-badge.thinking .pulse-dot {
  background: #F59E0B;
  box-shadow: 0 0 12rpx rgba(245, 158, 11, 0.6);
  animation: pulse-dot-fast 1s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% { 
    opacity: 1; 
    transform: scale(1); 
  }
  50% { 
    opacity: 0.6; 
    transform: scale(0.85); 
  }
}

@keyframes pulse-dot-fast {
  0%, 100% { 
    opacity: 1; 
    transform: scale(1); 
  }
  50% { 
    opacity: 0.4; 
    transform: scale(0.75); 
  }
}

.online-text {
  font-size: 22rpx;
  color: #10B981;
  font-weight: 500;
  transition: color 0.3s ease;
}

.online-badge.thinking .online-text {
  color: #F59E0B;
}

.nav-subtitle {
  font-size: 22rpx;
  color: var(--text-sub);
  font-weight: 400;
  margin-left: 2rpx;
}

.nav-actions {
  position: absolute;
  top: 120rpx;
  left: var(--input-padding-h);
  display: flex;
  gap: 16rpx;
  align-items: center;
  flex-direction: row;
}

.action-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid rgba(0, 0, 0, 0.04);
}

.action-btn:active {
  transform: scale(0.88);
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* TTS 按钮 - 开启状态 */
.tts-btn.active {
  background: linear-gradient(135deg, var(--primary) 0%, #FF9D7E 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 75, 75, 0.35);
  border-color: transparent;
}

.icon-speaker {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
}

.icon-speaker .speaker-body {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 14rpx solid #fff;
  position: relative;
}

.icon-speaker .speaker-body::after {
  content: '';
  position: absolute;
  right: -3rpx;
  top: -4rpx;
  width: 8rpx;
  height: 8rpx;
  background: #fff;
  border-radius: 2rpx;
}

.icon-speaker .speaker-waves {
  position: absolute;
  right: -4rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  gap: 4rpx;
  align-items: center;
}

.icon-speaker .wave-line {
  width: 4rpx;
  background: #fff;
  border-radius: 4rpx;
  animation: wave-anim 0.8s ease-in-out infinite;
}

.icon-speaker .wave-line:nth-child(1) {
  height: 12rpx;
  animation-delay: 0s;
}

.icon-speaker .wave-line:nth-child(2) {
  height: 20rpx;
  animation-delay: 0.15s;
}

.icon-speaker .wave-line:nth-child(3) {
  height: 12rpx;
  animation-delay: 0.3s;
}

@keyframes wave-anim {
  0%, 100% { transform: scaleY(0.6); opacity: 0.7; }
  50% { transform: scaleY(1); opacity: 1; }
}

/* TTS 按钮 - 静音状态 */
.icon-muted {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
}

.icon-muted .speaker-cone {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 14rpx solid #9CA3AF;
  position: relative;
}

.icon-muted .speaker-cone::after {
  content: '';
  position: absolute;
  right: -3rpx;
  top: -4rpx;
  width: 8rpx;
  height: 8rpx;
  background: #9CA3AF;
  border-radius: 2rpx;
}

.icon-muted .speaker-waves-muted {
  position: absolute;
  right: -4rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  gap: 3rpx;
  align-items: center;
}

.icon-muted .muted-wave {
  width: 3rpx;
  background: #D1D5DB;
  border-radius: 3rpx;
}

.icon-muted .muted-wave:nth-child(1) {
  height: 10rpx;
}

.icon-muted .muted-wave:nth-child(2) {
  height: 16rpx;
}

.icon-muted .mute-cross {
  position: absolute;
  right: -6rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 20rpx;
  height: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-muted .cross-line {
  position: absolute;
  width: 24rpx;
  height: 4rpx;
  background: #EF4444;
  border-radius: 2rpx;
}

.icon-muted .cross-line:first-child {
  transform: rotate(45deg);
}

.icon-muted .cross-line:last-child {
  transform: rotate(-45deg);
}

.tts-btn:not(.active):active {
  background: rgba(239, 68, 68, 0.1);
  border-color: rgba(239, 68, 68, 0.2);
}

/* 刷新按钮 */
.refresh-btn:active {
  transform: scale(0.88) rotate(180deg);
}

.refresh-icon {
  position: relative;
  width: 36rpx;
  height: 36rpx;
}

.refresh-circle {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #6B7280;
  border-top-color: transparent;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  transition: border-color 0.3s;
}

.refresh-btn:active .refresh-circle {
  border-color: var(--primary);
  border-top-color: transparent;
}

.refresh-arrow {
  position: absolute;
  right: 4rpx;
  top: 2rpx;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 8rpx solid #6B7280;
  transform: rotate(45deg);
  transition: border-bottom-color 0.3s;
}

.refresh-btn:active .refresh-arrow {
  border-bottom-color: var(--primary);
}

/* ========== 数字人区域 ========== */
.digital-human-section {
  position: relative;
  width: 100%;
  height: var(--human-height);
  margin-top: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 50;
  background: transparent;
  flex-shrink: 0;
}

.human-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.human-backdrop {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 360rpx;
  height: 360rpx;
  /* 核心光晕 + 外部柔和扩散 */
  background: radial-gradient(
    circle, 
    rgba(255, 75, 75, 0.15) 0%, 
    rgba(255, 157, 126, 0.08) 40%, 
    rgba(250, 248, 245, 0) 70%
  );
  border-radius: 50%;
  filter: blur(20rpx);
  z-index: 1; /* 在数字人背后 */
  animation: pulse 4s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { 
    transform: scale(1); 
    opacity: 0.6; 
  }
  50% { 
    transform: scale(1.15); 
    opacity: 0.8; 
  }
}

/* 数字人头像 */
.human-avatar {
  position: relative;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  z-index: 2;
  transition: all 0.3s;
  filter: drop-shadow(0 6rpx 20rpx rgba(255, 75, 75, 0.2));
}

.human-avatar.thinking {
  animation: thinking 2s ease-in-out infinite;
}

.human-avatar.speaking {
  animation: speaking 0.5s ease-in-out infinite;
}

@keyframes thinking {
  0%, 100% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(1.05) rotate(-2deg); }
  75% { transform: scale(1.05) rotate(2deg); }
}

@keyframes speaking {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

/* 声波动画 */
.sound-wave {
  display: flex;
  align-items: center;
  gap: 4rpx;
  height: 32rpx;
}

.wave-bar {
  width: 4rpx;
  background: linear-gradient(to top, var(--primary), #FF9D7E);
  border-radius: 4rpx;
  animation: wave 0.8s ease-in-out infinite;
}

.wave-bar:nth-child(1) { animation-delay: 0s; height: 12rpx; }
.wave-bar:nth-child(2) { animation-delay: 0.1s; height: 20rpx; }
.wave-bar:nth-child(3) { animation-delay: 0.2s; height: 28rpx; }
.wave-bar:nth-child(4) { animation-delay: 0.1s; height: 20rpx; }
.wave-bar:nth-child(5) { animation-delay: 0s; height: 12rpx; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.5); }
  50% { transform: scaleY(1); }
}

/* ========== 对话区域 ========== */
.chat-section {
  flex: 1;
  position: relative;
  z-index: 10;
  padding-top: 0;
  margin-top: -40rpx;
  overflow: hidden;
  background-color: transparent;
  border-radius: 0;
  padding-bottom: calc(var(--input-total-height) + env(safe-area-inset-bottom));
}

.chat-fade-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(to bottom, var(--bg-page) 10%, rgba(250, 248, 245, 0) 100%);
  z-index: 20;
  pointer-events: none;
}

.chat-scroll {
  width: 100%;
  height: 100%;
  padding: 20rpx var(--input-padding-h) 40rpx;
  box-sizing: border-box;
}

.message-item {
  display: flex;
  margin-bottom: 32rpx;
  animation: slideIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes slideIn {
  from { 
    opacity: 0; 
    transform: translateY(30rpx) scale(0.95); 
  }
  to { 
    opacity: 1; 
    transform: translateY(0) scale(1); 
  }
}

.user-message {
  flex-direction: row-reverse;
}

/* 头像 */
.avatar {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  margin: 0 16rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2px solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.avatar-text {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary) 0%, #FF9D7E 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255, 75, 75, 0.3);
}

/* 消息气泡 */
.message-bubble {
  max-width: 80%;
  padding: 24rpx 30rpx;
  border-radius: 24rpx;
  position: relative;
  word-break: break-word;
  transition: all 0.3s ease;
}

.ai-message .message-bubble {
  background: var(--card-bg);
  border: 1px solid rgba(0, 0, 0, 0.06);
  box-shadow: var(--shadow-card);
  border-top-left-radius: 8rpx;
}

.user-message .message-bubble {
  background: linear-gradient(135deg, var(--primary) 0%, #FF9D7E 100%);
  color: #fff;
  border-top-right-radius: 8rpx;
  box-shadow: 0 6rpx 24rpx rgba(255, 75, 75, 0.25);
}

.message-text {
  font-size: 30rpx;
  line-height: 1.6;
  white-space: pre-wrap;
}

.user-message .message-text {
  color: #fff;
}

/* Loading 动画 */
.loading-dots {
  display: flex;
  gap: 12rpx;
  padding: 8rpx 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #CBD5E1;
  border-radius: 50%;
  animation: dotBounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

/* ========== 快速问题 ========== */
.quick-questions {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1px solid rgba(0, 0, 0, 0.06);
}

.quick-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.quick-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.quick-item {
  padding: 18rpx 24rpx;
  background: linear-gradient(135deg, #FFF0F0 0%, #FFE5E5 100%);
  border: 1.5px solid rgba(255, 75, 75, 0.15);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #C93030;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 2rpx 12rpx rgba(255, 75, 75, 0.08);
}

.quick-item:active {
  transform: scale(0.97) translateY(2rpx);
  background: linear-gradient(135deg, #FFE5E5 0%, #FFD5D5 100%);
  box-shadow: 0 1rpx 6rpx rgba(255, 75, 75, 0.12);
}

.quick-toggle {
  margin-top: 16rpx;
  padding: 14rpx 28rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--primary);
  background: rgba(255, 75, 75, 0.05);
  border-radius: 24rpx;
  transition: all 0.3s ease;
  border: 1px solid rgba(255, 75, 75, 0.1);
}

.quick-toggle:active {
  background: rgba(255, 75, 75, 0.1);
  transform: scale(0.98);
}

/* ========== 输入区域 ========== */
.input-section {
  position: fixed;
  bottom: calc(var(--tabbar-height) + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  z-index: 100;
  padding: var(--input-padding-v) var(--input-padding-h);
  background: var(--bg-page);
}

.input-fade-mask {
  position: absolute;
  top: -20rpx;
  left: 0;
  right: 0;
  height: 20rpx;
  background: linear-gradient(to top, var(--bg-page), rgba(250, 248, 245, 0));
  pointer-events: none;
  z-index: -1;
}

.input-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: var(--input-height);
}

.input-wrapper {
  flex: 1;
  background: var(--card-bg);
  border: 2px solid rgba(255, 75, 75, 0.1);
  border-radius: 48rpx;
  padding: 0 var(--input-padding-h);
  height: 100%;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.input-wrapper:focus-within {
  border-color: rgba(255, 75, 75, 0.3);
  box-shadow: 0 6rpx 24rpx rgba(255, 75, 75, 0.12);
}

.input-box {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-main);
  height: 100%;
}

.input-placeholder {
  color: #9CA3AF;
}

/* 发送按钮 */
.send-btn {
  width: var(--input-height) !important;
  height: var(--input-height) !important;
  border-radius: 50% !important;
  background: #E5E7EB !important;
  padding: 0 !important;
  margin: 0 !important;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none !important;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08) !important;
}

.send-btn.active {
  background: linear-gradient(135deg, var(--primary) 0%, #FF9D7E 100%) !important;
  box-shadow: 0 6rpx 24rpx rgba(255, 75, 75, 0.4) !important;
  transform: scale(1.05);
}

.send-btn:active {
  transform: scale(0.92);
}

.send-btn[disabled] {
  opacity: 0.5;
}

.send-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(0.5);
}

.send-btn.active .send-icon {
  filter: brightness(0) invert(1);
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
  display: none;
}
