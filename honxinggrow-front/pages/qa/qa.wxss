/* QA 页面样式 - 参考 index 页面设计 */
page {
  --primary: #FF4B4B;
  --primary-light: #FFF0F0;
  --text-main: #1A1D26;
  --text-sub: #858B9C;
  --bg-page: #faf8f5;
  --card-bg: #FFFFFF;
  --shadow-soft: 0 10px 40px rgba(200, 200, 200, 0.15);
  --shadow-card: 0 8px 24px rgba(0, 0, 0, 0.04);
  
    --human-height: 340rpx;
  --input-height: 80rpx;
  --input-padding-v: 16rpx;
  --input-padding-h: 32rpx;
  --tabbar-height: 100rpx;
  --input-total-height: calc(var(--input-height) + var(--input-padding-v) * 2 + var(--tabbar-height));
  
  background-color: var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', sans-serif;
  height: 100vh;
  overflow: hidden;
}

/* 主容器 */
.qa-page {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  background-color: var(--bg-page);
  overflow: hidden;
}
/* ========== 胶囊导航栏 ========== */
.header-card {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding-top: calc(var(--status-bar-height, 44px) + 12rpx);
  padding-bottom: 16rpx;
  padding-left: 30rpx;
  background: transparent;
  box-sizing: border-box;
  display: flex;
  justify-content: flex-start;
}

/* 胶囊容器 - 毛玻璃效果 */
.header-capsule {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  max-width: 600rpx;
  width: auto;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 100rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08), 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}


/* 左侧：头像 */
.header-avatar-wrap {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.header-avatar.thinking {
  animation: avatar-thinking 2s ease-in-out infinite;
}

@keyframes avatar-thinking {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

/* 中间信息区 */
.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-left: 16rpx;
  min-width: 0;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 0.5px;
  line-height: 1.3;
}

.header-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.header-model {
  font-size: 22rpx;
  color: var(--text-sub);
  font-weight: 400;
  line-height: 1.3;
  margin-top: 2rpx;
}

/* 在线状态指示器 */
.header-status {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-right: 6rpx;
}

.status-dot.online {
  background: #52c41a;
  box-shadow: 0 0 4rpx rgba(82, 196, 26, 0.6);
}

.status-dot.offline {
  background: #ff4d4f;
  box-shadow: 0 0 4rpx rgba(255, 77, 79, 0.6);
}

.status-text {
  font-size: 20rpx;
  color: var(--text-sub);
  font-weight: 400;
}

/* 右侧操作按钮 */
.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-left: 60rpx;
  padding-left: 20rpx;
  border-left: 1rpx solid rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

/* 按钮分隔线 */
.action-divider {
  width: 1rpx;
  height: 32rpx;
  background: rgba(0, 0, 0, 0.1);
}


/* 图标按钮 */
.icon-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  background: transparent;
  border: none;
}

.icon-btn:active {
  transform: scale(0.9);
  opacity: 0.7;
}

.icon-text {
  font-size: 32rpx;
  line-height: 1;
}

/* 聊天按钮 */
.chat-btn .icon-text {
  opacity: 0.7;
}

/* 刷新按钮 */
.refresh-icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

.refresh-circle {
  width: 26rpx;
  height: 26rpx;
  border: 3rpx solid #6B7280;
  border-top-color: transparent;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.refresh-arrow {
  position: absolute;
  right: 2rpx;
  top: 2rpx;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 8rpx solid #6B7280;
  transform: rotate(45deg);
}

/* ========== 对话区域 ========== */
.chat-section {
  flex: 1;
  position: relative;
  z-index: 10;
  padding-top: 20rpx;
  margin-top: calc(var(--status-bar-height, 44px) + 120rpx);
  overflow: hidden;
  background-color: transparent;
  border-radius: 0;
  display: flex;
  flex-direction: column;
}

.chat-fade-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(to bottom, var(--bg-page) 10%, rgba(250, 248, 245, 0) 100%);
  z-index: 20;
  pointer-events: none;
}

.chat-scroll {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.chat-content {
  padding: 20rpx var(--input-padding-h) calc(var(--input-total-height) + 40rpx);
  min-height: 100%;
}

.message-item {
  display: flex;
  margin-bottom: 40rpx;
  animation: slideIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  align-items: flex-end;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(20rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.user-message {
  flex-direction: row-reverse;
}

/* 头像 - 精致化 */
.avatar {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  margin: 0 12rpx;
  border-radius: 50%;
  padding: 3rpx;
  background: linear-gradient(135deg, #fff 0%, #f0f0f0 100%);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx solid #fff;
  box-sizing: border-box;
}

.avatar-text {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary) 0%, #FF9D7E 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: inset 0 1rpx 2rpx rgba(255, 255, 255, 0.3);
}

/* 消息气泡 - 新拟态设计 */
.message-bubble {
  max-width: 78%;
  padding: 28rpx 32rpx;
  border-radius: 28rpx;
  position: relative;
  word-break: break-word;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* AI 消息 - 柔和的毛玻璃效果 */
.ai-message .message-bubble {
  background: linear-gradient(145deg, #ffffff 0%, #f8f9fa 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  box-shadow:
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    0 8rpx 24rpx rgba(0, 0, 0, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 1);
  border-bottom-left-radius: 8rpx;
}

/* AI 消息激活效果 */
.ai-message .message-bubble:active {
  transform: scale(0.98);
  box-shadow:
    0 1rpx 4rpx rgba(0, 0, 0, 0.03),
    0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 用户消息 - 柔和渐变 */
.user-message .message-bubble {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 50%, #FFB4B4 100%);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-bottom-right-radius: 8rpx;
  box-shadow:
    0 4rpx 12rpx rgba(255, 107, 107, 0.2),
    0 8rpx 28rpx rgba(255, 107, 107, 0.15),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

/* 用户消息光晕效果 */
.user-message .message-bubble::before {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.3) 0%, rgba(255, 180, 180, 0.1) 100%);
  border-radius: 30rpx;
  z-index: -1;
  filter: blur(8rpx);
  opacity: 0.6;
}

/* 用户消息激活效果 */
.user-message .message-bubble:active {
  transform: scale(0.98);
  box-shadow:
    0 2rpx 8rpx rgba(255, 107, 107, 0.15),
    0 4rpx 16rpx rgba(255, 107, 107, 0.1);
}

.message-text {
  font-size: 30rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  letter-spacing: 0.2rpx;
}

/* AI 消息文字 */
.ai-message .message-text {
  color: #2d3748;
}

.user-message .message-text {
  color: #fff;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* Loading 动画 */
.loading-dots {
  display: flex;
  gap: 12rpx;
  padding: 8rpx 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #CBD5E1;
  border-radius: 50%;
  animation: dotBounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

/* ========== 快速问题 ========== */
.quick-questions {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.quick-title {
  font-size: 24rpx;
  color: #718096;
  margin-bottom: 16rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.quick-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.quick-item {
  padding: 16rpx 22rpx;
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.08) 0%, rgba(255, 142, 142, 0.05) 100%);
  border: 1rpx solid rgba(255, 107, 107, 0.12);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #E85353;
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.05);
}

.quick-item:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.12) 0%, rgba(255, 142, 142, 0.08) 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.1);
}

.quick-toggle {
  margin-top: 16rpx;
  padding: 12rpx 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: #E85353;
  background: rgba(255, 107, 107, 0.06);
  border-radius: 20rpx;
  transition: all 0.25s ease;
  border: 1rpx solid rgba(255, 107, 107, 0.1);
}

.quick-toggle:active {
  background: rgba(255, 107, 107, 0.1);
  transform: scale(0.98);
}

/* ========== 输入区域 ========== */
.input-section {
  position: fixed;
  /* bottom: calc(150rpx + env(safe-area-inset-bottom)); 已改为在 wxml 中动态设置 */
  left: 0;
  right: 0;
  z-index: 100;
  padding: var(--input-padding-v) var(--input-padding-h);
  background: var(--bg-page);
}

.input-fade-mask {
  position: absolute;
  top: -20rpx;
  left: 0;
  right: 0;
  height: 20rpx;
  background: linear-gradient(to top, var(--bg-page), rgba(250, 248, 245, 0));
  pointer-events: none;
  z-index: -1;
}

.input-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: var(--input-height);
}

.input-wrapper {
  flex: 1;
  background: var(--card-bg);
  border: 2px solid rgba(255, 75, 75, 0.1);
  border-radius: 48rpx;
  padding: 0 var(--input-padding-h);
  height: 100%;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.input-wrapper:focus-within {
  border-color: rgba(255, 75, 75, 0.3);
  box-shadow: 0 6rpx 24rpx rgba(255, 75, 75, 0.12);
}

.input-box {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-main);
  height: 100%;
}

.input-placeholder {
  color: #9CA3AF;
}

/* 发送按钮 */
.send-btn {
  width: var(--input-height) !important;
  height: var(--input-height) !important;
  border-radius: 50% !important;
  background: #E5E7EB !important;
  padding: 0 !important;
  margin: 0 !important;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none !important;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08) !important;
}

.send-btn.active {
  background: linear-gradient(135deg, var(--primary) 0%, #FF9D7E 100%) !important;
  box-shadow: 0 6rpx 24rpx rgba(255, 75, 75, 0.4) !important;
  transform: scale(1.05);
}

.send-btn:active {
  transform: scale(0.92);
}

.send-btn[disabled] {
  opacity: 0.5;
}

.send-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(0.5);
}

.send-btn.active .send-icon {
  filter: brightness(0) invert(1);
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
  display: none;
}

/* 消息气泡内的播放按钮 */
.tts-play-btn {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(255, 75, 75, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.tts-play-btn:active {
  transform: scale(0.9);
  background: rgba(255, 75, 75, 0.2);
}

.play-icon {
  width: 24rpx;
  height: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-triangle {
  width: 0;
  height: 0;
  border-left: 14rpx solid var(--primary);
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  margin-left: 4rpx;
}

.pause-bars {
  display: flex;
  gap: 6rpx;
  align-items: center;
  height: 20rpx;
}

.pause-bars .bar {
  width: 6rpx;
  height: 20rpx;
  background: var(--primary);
  border-radius: 2rpx;
  animation: pulse-bar 0.5s ease-in-out infinite alternate;
}

.pause-bars .bar:nth-child(2) {
  animation-delay: 0.15s;
}

@keyframes pulse-bar {
  0% { height: 12rpx; }
  100% { height: 20rpx; }
}

/* ========== 底部填充遮罩 ========== */
.bottom-fill-mask {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-page);
  z-index: 99;
}
