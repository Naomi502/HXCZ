  /* app.wxss */
  page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  color: #333;
  background-color: #faf8f5;
  line-height: 1.5;
}

  .container {
    padding: 0;
    margin: 0;
    box-sizing: border-box;
  }

  /* 通用样式 */
  .section {
    background: #fff;
    margin-bottom: 10px;
    padding: 15px;
  }

  /* 卡片样式 */
  .card {
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    padding: 15px;
    margin-bottom: 12px;
  }

  /* 字体样式 */
  .title {
    font-size: 16px;
    font-weight: bold;
    margin-bottom: 10px;
    color: #333;
  }

  .subtitle {
    font-size: 14px;
    color: #666;
    margin-bottom: 8px;
  }

  .content {
    font-size: 14px;
    color: #666;
    line-height: 1.6;
  }

  /* 分割线 */
  .line {
    height: 1px;
    background: #f0f0f0;
    margin: 10px 0;
  }

  /* 图标样式 */
  .icon {
    width: 24px;
    height: 24px;
  }

  /* 底部导航栏 */
  .tab-bar {
    display: flex;
    justify-content: space-around;
    align-items: center;
    background: #fff;
    border-top: 1px solid #f0f0f0;
    padding: 10px 0;
  }

  .tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    font-size: 12px;
    color: #999;
    padding: 5px 0;
  }

  .tab-item.active {
    color: #ff6700;
  }

  .tab-icon {
    width: 28px;
    height: 28px;
    margin-bottom: 2px;
  }

/* === Page Transition Animations (Shared) === */
@keyframes slideDownEntry {
  from { opacity: 0; transform: translateY(-20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUpEntry {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInEntry {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes popEntry {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(72, 255, 148, 0.4); }
  70% { box-shadow: 0 0 0 6px rgba(72, 255, 148, 0); }
  100% { box-shadow: 0 0 0 0 rgba(72, 255, 148, 0); }
}

/* 
   Only apply animations when the parent has .animate-entry class.
   This allows us to control when the animation plays (e.g. on tab switch).
*/
.anim-reset .animate-slide-down,
.anim-reset .animate-slide-up,
.anim-reset .animate-fade-in,
.anim-reset .animate-pop {
  opacity: 0 !important;
  animation: none !important;
}

.animate-entry .animate-slide-down {
  animation: slideDownEntry 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  opacity: 0;
}

.animate-entry .animate-slide-up {
  animation: slideUpEntry 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  opacity: 0;
}

.animate-entry .animate-fade-in {
  animation: fadeInEntry 0.4s ease-out forwards;
  opacity: 0;
}

.animate-entry .animate-pop {
  animation: popEntry 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  opacity: 0;
}
